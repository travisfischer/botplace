# 1Password env-template for local dev. Read by `op run --env-file=op.env -- <cmd>`
# (and by the convenience wrapper `pnpm op <cmd>`).
#
# Convention:
#   - Secret values reference 1Password items via `op://` URIs.
#   - Non-secret identifiers (project ids, etc.) may appear as literals if
#     they don't fit naturally in the 1Password Agents vault.
#   - See docs/dev/secrets.md for the source-of-truth table and
#     docs/dev/setup.md § Running commands with secrets for usage.
#
# This file contains NO plaintext secrets and is safe to commit. The
# actual values live in 1Password under the `Agents` vault.

# ---- Neon (db:bootstrap, db:branch:cleanup, db:migrate:* via prisma.config) ----
NEON_API_KEY="op://Agents/Neon/credential"
NEON_PROJECT_ID="op://Agents/Neon/project id"

# ---- Google OAuth (only needed if you sign in via Google during dev) ----
# Both halves resolve to process env at command-run time. `pnpm db:bootstrap`
# additionally persists GOOGLE_CLIENT_ID (non-secret) to `.env` so plain
# `pnpm dev` works without the `pnpm op` wrapper. The SECRET half is
# process-env-only — never written to `.env`.
GOOGLE_CLIENT_ID="op://Agents/Botplace Google OAuth/client id"
GOOGLE_CLIENT_SECRET="op://Agents/Botplace Google OAuth/credential"

# ---- Admin token (only needed for `pnpm admin:*` scripts) ----
ADMIN_TOKEN="op://Agents/Botplace Admin Token/credential"

# ---- Vercel CLI (only needed for prod-only probes: `vercel env pull`, etc.) ----
# Uncomment if your local environment doesn't already carry `VERCEL_TOKEN`.
# VERCEL_TOKEN="op://Agents/Vercel/credential"

# ---- Upstash (optional in dev — lib/rate-limit.ts falls back to in-memory) ----
# Uncomment to test rate-limit behavior against real Upstash from a dev session.
# UPSTASH_REDIS_REST_URL="op://Agents/Botplace Upstash Redis/rest url"
# UPSTASH_REDIS_REST_TOKEN="op://Agents/Botplace Upstash Redis/credential"

# ---- M2.5 launch-bot keys (production-only) ----
# These are issued by `pnpm m25:seed-launch-bots` and live in Vercel
# project env (Production scope) — NOT in 1Password and NOT in op.env.
# They're consumed by the cron routes at runtime, not by any local
# script. See docs/dev/probes/m2.5-launch-bots.md.
#
#   M25_VISITOR_PULSE_KEY  — POWER-tier bot key
#   M25_SPARKLE_KEY        — POWER-tier bot key
#   M25_CONWAY_KEY         — POWER-tier bot key
#   CRON_SECRET            — auto-managed by Vercel when crons are configured
#   M25_BOTS_ENABLED       — soft-launch gate ("true" wakes the bots)
