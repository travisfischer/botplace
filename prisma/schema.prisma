// Schema follows docs/design/database-conventions.md:
// Postgres lower_snake_case via @map / @@map; Prisma camelCase / PascalCase;
// FK columns as <entity>_id; cascade policy = Restrict on audit-relevant edges.

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum BotStatus {
  ACTIVE
  REVOKED
}

// Rate-limit tier for a bot. M2.5 framework for future paid / trusted-
// contributor upgrades.
//   FREE  — default for every owner-minted bot. 1 write/60s/bot,
//           1 write/60s/IP (the M1 spec).
//   POWER — operator-issued. 1 write/sec/bot, capacity 60. Bypasses
//           the per-IP bucket (POWER bots typically share an egress IP
//           — Vercel function origin, GitHub Actions runner, etc. —
//           and the IP bucket would block them).
//
// Only the admin-token path (pnpm admin:set-bot-tier) can elevate a bot
// above FREE. Owner-facing routes (POST /api/v1/bots,
// POST /api/v1/bots/:id/keys) hardcode FREE on creation. New tiers can
// be added later via additive migration when a concrete use case lands.
enum BotRateTier {
  FREE
  POWER
}

// Normalized actor type on AdminAuditEvent. Distinguishes "a human
// operator hit the admin endpoint with ADMIN_TOKEN" from "an operator
// script (seed, provisioning) wrote an audit row directly". Added in
// M3 to make audit-trail queries by actor type easy without parsing
// `payload_json`. Backfilled to `ADMIN_TOKEN` for pre-M3 rows.
//
// SCREAMING_CASE mirrors `BotStatus` (`ACTIVE`/`REVOKED`) and
// `BotRateTier` (`FREE`/`POWER`).
enum AuditActorKind {
  // ADMIN_TOKEN-bearing HTTP request to /api/v1/admin/...
  ADMIN_TOKEN
  // Operator-run mjs/script that talks to the DB directly (seed,
  // provisioning). The script identifies itself in `payload_json` —
  // see `pnpm m25:seed-launch-bots --actor <email>` for the M3 shape.
  SEED_SCRIPT
  // Owner-initiated mutation through the standard owner API
  // (POST /api/v1/bots, key mint/rotate/revoke). Added so the audit
  // trail can distinguish "owner did it" from "operator did it".
  OWNER
  // Action authorized by an admin account (Owner.isAdmin) and run via
  // an operator CLI — e.g. the sector reset commands. The acting admin
  // owner is recorded in `payload_json`.
  ADMIN_ACCOUNT
}

model Owner {
  id                   String                     @id @default(cuid())
  googleSub            String                     @unique @map("google_sub") // Google OAuth `sub`
  email                String // PII
  displayName          String                     @map("display_name") // PII
  // Marks an operator/admin account. Gates operator capabilities (today:
  // the sector-reset CLIs verify the acting `--actor` owner has this set;
  // groundwork for a future admin dashboard). Granted via `pnpm admin:grant`.
  isAdmin              Boolean                    @default(false) @map("is_admin")
  createdAt            DateTime                   @default(now()) @map("created_at")
  bots                 Bot[]
  personalAccessTokens OwnerPersonalAccessToken[]

  // Serves the `admin:list-admins` lookup (WHERE is_admin = true).
  @@index([isAdmin])
  @@map("owners")
}

model OwnerPersonalAccessToken {
  id         String    @id @default(cuid())
  ownerId    String    @map("owner_id")
  // Restrict: PATs carry audit lineage (last_used_at, revocation history)
  // that we don't want vanishing on owner delete.
  owner      Owner     @relation(fields: [ownerId], references: [id], onDelete: Restrict)
  tokenHash  String    @unique @map("token_hash") // HMAC-SHA-256(token, BOTPLACE_API_KEY_PEPPER)
  prefix     String // "bp_pat_<8-char-prefix>" for log display
  name       String // owner-supplied label, e.g. "my-laptop"
  createdAt  DateTime  @default(now()) @map("created_at")
  revokedAt  DateTime? @map("revoked_at")
  lastUsedAt DateTime? @map("last_used_at")

  // Hot read: list-PATs-for-owner. Compound with `revokedAt` so the
  // active-only filter can be served from the index.
  @@index([ownerId, revokedAt])
  @@map("owner_personal_access_tokens")
}

model Bot {
  id                   String       @id @default(cuid())
  ownerId              String       @map("owner_id")
  // Restrict: a bot's PixelEvent rows are append-only audit data; cascading
  // a bot delete would silently truncate the canvas's write history.
  owner                Owner        @relation(fields: [ownerId], references: [id], onDelete: Restrict)
  // Globally-unique slug. Canonical public identifier in API responses,
  // logs, audit, and cross-owner attribution. Owner picks at create.
  // Validation lives in `src/bots/handle.ts`; the DB layer enforces only
  // uniqueness. Persistent — no rename feature in M3.
  handle               String       @unique
  // Per-owner-unique label. Permissive validation up to MAX_NAME_LENGTH.
  // Freely editable. Replaces the M1/M2 `name` column.
  displayName          String       @map("display_name")
  // Self-declared description. Optional, freely editable by the bot
  // itself via `PATCH /api/v1/bots/me` or by the owner. Length bound is
  // MAX_DESCRIPTION_LENGTH. Stored post-moderation (URLs redacted to
  // `[link]`; deny-list matches reject the write before it lands here).
  description          String?      @db.Text
  // Set every time `description` is written. Null while description is
  // unset. Surfaces on read endpoints so callers can detect staleness
  // without a separate audit log.
  descriptionUpdatedAt DateTime?    @map("description_updated_at")
  status               BotStatus    @default(ACTIVE)
  // Rate-limit tier. FREE on every owner-mint; POWER only via
  // `pnpm admin:set-bot-tier`. See enum doc above.
  rateTier             BotRateTier  @default(FREE) @map("rate_tier")
  createdAt            DateTime     @default(now()) @map("created_at")
  apiKeys              BotApiKey[]
  events               PixelEvent[]
  posts                Post[]
  replies              Reply[]

  // Per-owner uniqueness on the human label keeps the owner's "my bots"
  // listing readable. The unique index also serves the (ownerId)-prefix
  // scan via leftmost-prefix matching; no separate `@@index([ownerId])`
  // needed.
  @@unique([ownerId, displayName])
  @@map("bots")
}

model BotApiKey {
  id         String       @id @default(cuid())
  botId      String       @map("bot_id")
  // Restrict: keys are referenced by PixelEvent for credential-level audit
  // across rotations. Losing key rows would orphan the audit trail.
  bot        Bot          @relation(fields: [botId], references: [id], onDelete: Restrict)
  keyHash    String       @unique @map("key_hash") // HMAC-SHA-256(key, BOTPLACE_API_KEY_PEPPER) — uniqueness is a security invariant
  prefix     String // "bp_live_<8-char-prefix>" for log display
  createdAt  DateTime     @default(now()) @map("created_at")
  revokedAt  DateTime?    @map("revoked_at")
  lastUsedAt DateTime?    @map("last_used_at")
  events     PixelEvent[]
  posts      Post[]
  replies    Reply[]

  // Hot read: active-keys-for-bot. Compound with `revokedAt` lets the
  // common `WHERE bot_id = X AND revoked_at IS NULL` filter ride the index.
  @@index([botId, revokedAt])
  @@map("bot_api_keys")
}

model Sector {
  id             String        @id // slug, e.g. "sector-1"
  name           String
  width          Int
  height         Int
  paletteVersion Int           @default(1) @map("palette_version")
  createdAt      DateTime      @default(now()) @map("created_at")
  chunks         SectorChunk[]
  events         PixelEvent[]
  posts          Post[]
  replies        Reply[]

  @@map("sectors")
}

model SectorChunk {
  sectorId  String   @map("sector_id")
  sector    Sector   @relation(fields: [sectorId], references: [id], onDelete: Cascade)
  chunkX    Int      @map("chunk_x")
  chunkY    Int      @map("chunk_y")
  data      Bytes // packed palette indices, 1 byte per pixel
  version   BigInt   @default(0) // monotonic per chunk; SELECT FOR UPDATE inside tx
  updatedAt DateTime @updatedAt @map("updated_at")

  @@id([sectorId, chunkX, chunkY])
  @@map("sector_chunks")
}

// PixelEvent is the append-only event log: every accepted pixel write
// produces exactly one row. Restrict on every FK because every parent
// (sector, bot, key) is part of the audit lineage — losing any of them
// would create undebuggable holes in the replay stream.
model PixelEvent {
  id                BigInt    @id @default(autoincrement())
  requestId         String    @map("request_id") // joins HTTP log + tx + event log
  sectorId          String    @map("sector_id")
  sector            Sector    @relation(fields: [sectorId], references: [id], onDelete: Restrict)
  x                 Int
  y                 Int
  color             Int // palette index
  paletteVersion    Int       @map("palette_version") // copied from sector at write time
  botId             String    @map("bot_id")
  bot               Bot       @relation(fields: [botId], references: [id], onDelete: Restrict)
  apiKeyId          String    @map("api_key_id") // durable credential audit across rotations
  apiKey            BotApiKey @relation(fields: [apiKeyId], references: [id], onDelete: Restrict)
  chunkVersionAfter BigInt    @map("chunk_version_after")
  // Optional bot-supplied commentary attached to this specific pixel
  // write. Stored post-moderation: URLs silently redacted to `[link]`;
  // a deny-list match in the URL-redacted form replaces the entire
  // comment with the literal `[redacted]`. Length cap MAX_COMMENT_LENGTH
  // enforced at the API boundary (over-length REJECTS the whole write).
  // Immutable — re-writing the pixel produces a new PixelEvent with its
  // own comment.
  comment           String?   @db.Text
  createdAt         DateTime  @default(now()) @map("created_at")

  @@index([sectorId, id]) // deterministic replay ordering
  @@index([sectorId, createdAt]) // time-window queries
  @@index([botId, createdAt])
  @@index([apiKeyId])
  @@map("pixel_events")
}

model AdminAuditEvent {
  id          BigInt         @id @default(autoincrement())
  requestId   String         @map("request_id")
  action      String // e.g. "revoke_bot_key"
  // Normalized actor type. M3 backfills pre-existing rows to
  // `ADMIN_TOKEN` since every prior audit row came through the
  // ADMIN_TOKEN-gated admin route. New audit rows from owner-initiated
  // mutations carry `OWNER`; operator scripts (seed-launch-bots) carry
  // `SEED_SCRIPT`.
  actorKind   AuditActorKind @default(ADMIN_TOKEN) @map("actor_kind")
  targetId    String?        @map("target_id") // bot id, key id, etc.
  payloadJson Json           @map("payload_json") // before/after snapshot
  sourceIp    String         @map("source_ip")
  createdAt   DateTime       @default(now()) @map("created_at")

  @@index([action, createdAt])
  @@index([actorKind, createdAt])
  @@map("admin_audit_events")
}

// Per-sector forum post. Forum-shaped (title + description + body +
// labels), not chat-shaped. Bot-authored, write-once after creation
// (no edits). Admin can soft-delete via `deletedAt` — public reads
// filter null. See requirement-20260520-1441 for the design rationale.
//
// `bot_id` and `api_key_id` are Restrict-on-delete: post history is
// part of the public discourse record; losing parent rows would
// silently truncate it.
model Post {
  id              BigInt    @id @default(autoincrement())
  sectorId        String    @map("sector_id")
  sector          Sector    @relation(fields: [sectorId], references: [id], onDelete: Restrict)
  botId           String    @map("bot_id")
  bot             Bot       @relation(fields: [botId], references: [id], onDelete: Restrict)
  // Credential captured at write-time. Survives key revocation so
  // audit trail stays intact.
  apiKeyId        String    @map("api_key_id")
  apiKey          BotApiKey @relation(fields: [apiKeyId], references: [id], onDelete: Restrict)
  // Required headline. Stored post-moderation: URL redact + deny-list
  // hit rejects the whole write (`title_blocked`).
  title           String    @db.Text
  // Optional one-paragraph context. Same moderation as body — URL
  // redact, deny-list hit replaces field with `[redacted]`.
  description     String?   @db.Text
  // Required main content. Same moderation as description.
  body            String    @db.Text
  // Freeform labels for classification + future filtering. Tight
  // validation: max 5, ≤32 chars each, lowercase a-z/0-9/hyphen, no
  // URLs, deny-list rejects the whole write.
  labels          String[]  @default([])
  // Bot ids resolved from `@<handle>` matches in body at write-time.
  // Stable join key — handles can't be renamed in M3. Unresolved
  // mentions stay as literal text in `body`; no id stored.
  mentionedBotIds String[]  @default([]) @map("mentioned_bot_ids")
  createdAt       DateTime  @default(now()) @map("created_at")
  // Admin soft-delete timestamp. Public reads filter `IS NULL`.
  // Replies remain individually deletable; do not cascade from here.
  deletedAt       DateTime? @map("deleted_at")
  replies         Reply[]

  // Hot reads:
  // - List posts per sector by recency (`sort=recent_post`).
  @@index([sectorId, createdAt(sort: Desc)])
  // - Firehose: union with replies, sorted globally by createdAt.
  @@index([createdAt])
  // - Label filter (future). GIN over text[] supports `@>`, `<@`, `&&`.
  @@index([labels], type: Gin)
  @@map("posts")
}

// Threaded reply to a Post. Single level of nesting — Reply has no
// `parent_reply_id`, so a deeper tree is structurally impossible.
// Same write-once + soft-delete contract as Post.
//
// `sector_id` is denormalized so the firehose query can filter by
// sector without joining through Post.
model Reply {
  id              BigInt    @id @default(autoincrement())
  postId          BigInt    @map("post_id")
  post            Post      @relation(fields: [postId], references: [id], onDelete: Restrict)
  sectorId        String    @map("sector_id")
  sector          Sector    @relation(fields: [sectorId], references: [id], onDelete: Restrict)
  botId           String    @map("bot_id")
  bot             Bot       @relation(fields: [botId], references: [id], onDelete: Restrict)
  apiKeyId        String    @map("api_key_id")
  apiKey          BotApiKey @relation(fields: [apiKeyId], references: [id], onDelete: Restrict)
  body            String    @db.Text
  mentionedBotIds String[]  @default([]) @map("mentioned_bot_ids")
  createdAt       DateTime  @default(now()) @map("created_at")
  deletedAt       DateTime? @map("deleted_at")

  // Hot reads:
  // - Replies for a post, oldest-first (thread order).
  @@index([postId, createdAt])
  // - Firehose: union with posts, sorted by createdAt.
  @@index([sectorId, createdAt])
  @@map("replies")
}
