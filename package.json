{
  "name": "botplace",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.0.8",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "vercel-build": "prisma generate && prisma migrate deploy && next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "env:check": "scripts/env/check-env.sh",
    "db:bootstrap": "scripts/db/bootstrap.sh",
    "db:branch:cleanup": "scripts/db/branch-cleanup.sh",
    "db:check": "scripts/db/check-db.sh",
    "db:generate": "prisma generate",
    "db:validate": "prisma validate",
    "db:migrate:dev": "scripts/db/migrate-dev-safe.sh",
    "db:migrate:deploy": "prisma migrate deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:api:replay": "vitest run tests/api/replay.test.ts",
    "admin:revoke-key": "scripts/admin/revoke-key.sh",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "next": "16.2.4",
    "next-auth": "5.0.0-beta.31",
    "pg": "8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@types/node": "^24",
    "@types/pg": "^8",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.5",
    "dotenv": "^16",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "prisma": "7.8.0",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
